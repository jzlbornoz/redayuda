# Copia este archivo a .env.production en el homelab y rellena las claves.
# NO lo subas a git (esta en .gitignore).

APP_NAME=Red Humanitaria de Datos

# Clave de la API externa de hospitales (si se va a sincronizar esa fuente).
HOSPITALES_API_KEY=

# Protegen las escrituras. En produccion DEBEN estar definidas (fail-closed):
# si quedan vacias, /api/ingest y /api/sources/.../sync responden 503.
INGEST_API_KEY=
ADMIN_API_KEY=

# Identidad de este nodo en la red federada.
NODE_ID=homelab

# Federacion PULL (desactivada por defecto; activar cuando haya peers).
FEDERATION_PULL_ENABLED=0
FEDERATION_PULL_INTERVAL_SECONDS=300
FEDERATION_PULL_LIMIT=200

# Registro self-service de fuentes.
PROPOSALS_ENABLED=1
PROPOSAL_RATE_LIMIT=5

# Credenciales de conectores de aliados (no se versionan; ponlas aqui en el homelab).
# Apoyo SaluPro: token por aliado (revocable) para GET /api/export.
APOYO_SALUPRO_TOKEN=
# Vnzla Ayuda: clave publishable de Supabase (publica por diseno; ya trae default en el conector).
VNZLA_AYUDA_KEY=

# Ingesta recurrente: sincroniza los conectores habilitados cada N segundos.
# Las fuentes pesadas (auto_sync=False: Apoyo SaluPro, Encuentralos, HF) NO entran
# en este ciclo; se sincronizan a demanda con POST /api/sources/{id}/sync o sync-all.
# Re-sync es barato (content_hash salta lo no cambiado). 21600 = cada 6 h.
AUTO_SYNC_ENABLED=1
AUTO_SYNC_INTERVAL_SECONDS=21600
AUTO_SYNC_SOURCE_LIMIT=5000
AUTO_SYNC_MAX_PAGES=10

# Lecturas para muchos consumidores: rate-limit por IP (req/min, 0 desactiva) y
# Cache-Control corto en GET de la API (segundos) para que el borde (Cloudflare) cachee.
READ_RATE_LIMIT_PER_MIN=120
READ_CACHE_SECONDS=30

# NO toques DATABASE_PATH: el contenedor lo fija a /data/index.db (volumen).
