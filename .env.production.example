# Copia este archivo a .env.production en el homelab y rellena las claves.
# NO lo subas a git (esta en .gitignore).

APP_NAME=Red Humanitaria de Datos

# Clave de la API externa de hospitales (si se va a sincronizar esa fuente).
HOSPITALES_API_KEY=

# Protegen las escrituras. En produccion DEBEN estar definidas (fail-closed):
# si quedan vacias, /api/ingest y /api/sources/.../sync responden 503.
INGEST_API_KEY=
ADMIN_API_KEY=

# Identidad de este nodo en la red federada.
NODE_ID=homelab

# Federacion PULL (desactivada por defecto; activar cuando haya peers).
FEDERATION_PULL_ENABLED=0
FEDERATION_PULL_INTERVAL_SECONDS=300
FEDERATION_PULL_LIMIT=200

# Registro self-service de fuentes.
PROPOSALS_ENABLED=1
PROPOSAL_RATE_LIMIT=5

# Ingesta recurrente: sincroniza los conectores habilitados cada N segundos.
# Activa esto para mantener el indice fresco automaticamente (3600 = cada hora).
AUTO_SYNC_ENABLED=1
AUTO_SYNC_INTERVAL_SECONDS=3600
AUTO_SYNC_SOURCE_LIMIT=5000
AUTO_SYNC_MAX_PAGES=10

# NO toques DATABASE_PATH: el contenedor lo fija a /data/index.db (volumen).
