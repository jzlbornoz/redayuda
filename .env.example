APP_NAME=Red Humanitaria de Datos
HOSPITALES_API_KEY=pega_aqui_tu_clave
INGEST_API_KEY=clave_para_apps_aliadas
ADMIN_API_KEY=clave_para_sincronizar_fuentes
DATABASE_PATH=data/index.db
UPSTREAM_URL=https://ozuxfepfkvnxkywdsqxy.supabase.co/functions/v1/export-pacientes
REQUEST_TIMEOUT_SECONDS=15
DEFAULT_SOURCE_LIMIT=1000
DEFAULT_MAX_PAGES=5
# Seguridad: por defecto las escrituras requieren clave configurada (fail-closed).
# Activa ALLOW_OPEN_WRITES solo en desarrollo local para escribir sin clave.
ALLOW_OPEN_WRITES=0
SQLITE_BUSY_TIMEOUT_MS=5000
# Federacion: identidad de este nodo y sondeo de peers (PULL).
NODE_ID=
FEDERATION_PULL_ENABLED=0
FEDERATION_PULL_INTERVAL_SECONDS=300
FEDERATION_PULL_LIMIT=200
